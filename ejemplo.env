# ================================
# CONFIGURACIÓN PRINCIPAL DEL SISTEMA
# ================================

# Google Sheets - URL completa de tu hoja (OBLIGATORIO)
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/1kKnK7FFqg9STRHVJIbDSK1LK8CEO2uCGiZhGG94VzlI/edit?usp=sharing

# Google Sheets - ID extraído de la URL (OBLIGATORIO)
GOOGLE_SHEETS_ID=1kKnK7FFqg9STRHVJIbDSK1LK8CEO2uCGiZhGG94VzlI

# Rango de celdas a leer (OPCIONAL)
GOOGLE_SHEETS_RANGE=Sheet1!A:O

# ================================
# CONFIGURACIÓN DEL BOT (ALEMANIA Y COLOMBIA)
# ================================

# Nombre del bot que aparecerá en los mensajes
BOT_NAME=TerminBot

# Nombre de tu empresa
COMPANY_NAME=International Services

# Código de país por defecto (49=Alemania, 57=Colombia)
DEFAULT_COUNTRY_CODE=49

# ================================
# CONFIGURACIÓN DE WHATSAPP
# ================================

# Nombre de sesión de WhatsApp (para guardar la autenticación)
WHATSAPP_SESSION_NAME=whatsapp-appointment-bot

# ================================
# CONFIGURACIÓN DE EXCEL
# ================================

# Nombre del archivo Excel donde se guardarán las citas
EXCEL_OUTPUT_FILE=citas_agendadas.xlsx

# ================================
# MENSAJES BILINGÜES (ALEMÁN/ESPAÑOL)
# ================================

# Mensaje de saludo bilingüe
GREETING_MESSAGE=Hello! We are contacting you to schedule your appointment. Please select the time that works best for you. | ¡Hola! Te contactamos para agendar tu cita. Por favor selecciona el horario que mejor te convenga.

# Mensaje de confirmación (usa {time} para el horario)
CONFIRMATION_MESSAGE=Perfect! Your appointment has been scheduled for {time}. We will send you a reminder. | ¡Perfecto! Tu cita ha sido agendada para las {time}. Te enviaremos un recordatorio.

# Mensaje de rechazo
REJECTION_MESSAGE=Understood. If you change your mind, do not hesitate to contact us. | Entendido. Si cambias de opinión, no dudes en contactarnos.

# ================================
# MENSAJES SOLO EN ALEMÁN (OPCIONAL)
# ================================
# Descomenta estas líneas si quieres mensajes solo en alemán:

# GREETING_MESSAGE=Hallo! Wir kontaktieren Sie, um Ihren Termin zu vereinbaren. Bitte wählen Sie die Zeit, die Ihnen am besten passt:
# CONFIRMATION_MESSAGE=Perfekt! Ihr Termin wurde für {time} vereinbart. Wir senden Ihnen eine Erinnerung.
# REJECTION_MESSAGE=Verstanden. Wenn Sie Ihre Meinung ändern, zögern Sie nicht, uns zu kontaktieren.

# ================================
# GOOGLE API (OPCIONAL - Solo para acceso avanzado)
# ================================
# Deja vacío si usas hoja pública

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
